{
  "expo": {
    "name": "МАСШТАБ",
    "slug": "mashtab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mashtab",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0D0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dangrow.mashtab",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0F0D0B"
      },
      "package": "com.dangrow.mashtab"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5e95f8e-937b-40d1-a8fe-69d3f86dd5fe"
      }
    },
    "owner": "shineshopb2b"
  }
}
